generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String
  createdAt DateTime @default(now())
}

model Case {
  id          String   @id @default(cuid())
  title       String
  courtName   String
  status      String
  hearingDate DateTime
  createdAt   DateTime @default(now())
}