generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Client {
  id            String        @id @default(cuid())
  name          String
  phone         String
  address       String
  createdAt     DateTime      @default(now())
  cases         Case[]
  notaryEntries NotaryEntry[]
  invoices      Invoice[]
}

model Case {
  id          String    @id @default(cuid())
  title       String
  courtName   String
  status      String
  hearingDate DateTime
  createdAt   DateTime  @default(now())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
}

model NotaryEntry {
  id           String   @id @default(cuid())
  serialNo     Int      @unique @default(autoincrement())
  notaryDate   DateTime @default(now())
  documentName String   // e.g. Affidavit, Agreement, GPA, Sale Deed
  executants   String   // Name(s) of people executing the document
  witnesses    String   // Name(s) of witnesses
  stampDuty    Float    @default(0) // Stamp duty paid in ₹
  notaryFee    Float    @default(0) // Notary fee collected in ₹
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber Int           @unique @default(autoincrement())
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime
  status        String        // Paid, Unpaid, Overdue
  tax           Float         @default(0)  // Tax percentage (e.g. GST)
  discount      Float         @default(0)  // Discount value in ₹
  totalAmount   Float         // Calculated total in ₹
  paymentMethod String        @default("Cash") // Cash, UPI, Bank Transfer, Cheque
  remarks       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  caseId        String?
  case          Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)
  
  items         InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  description String   // Line item description (e.g. Consultation fee)
  quantity    Int      @default(1)
  unitPrice   Float    // Price per unit in ₹
  amount      Float    // quantity * unitPrice in ₹
  
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}